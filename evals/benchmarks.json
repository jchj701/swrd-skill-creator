{
  "skill_name": "swrd-skill-creator",
  "eval_type": "benchmark",
  "description": "SWRD Skill 性能基准测试",
  "performance_metrics": {
    "token_usage": {
      "soft_limit": 24000,
      "hard_limit": 48000,
      "target": "< 20000",
      "unit": "tokens"
    },
    "latency": {
      "target": 30000,
      "p50": "< 20000",
      "p95": "< 40000",
      "p99": "< 60000",
      "unit": "ms"
    },
    "completion_rate": {
      "target": ">= 85%",
      "minimum": ">= 80%"
    }
  },
  "quality_metrics": {
    "trigger_accuracy": {
      "target": ">= 90%",
      "minimum": ">= 85%"
    },
    "output_completeness": {
      "target": "100%",
      "required_files": [
        "SKILL.md",
        "skill.yaml",
        "workflows/state-machine.yaml",
        "evals/trigger_cases.json",
        "evals/success_cases.json",
        "evals/failure_cases.json",
        "telemetry/<skill-name>-telemetry.yaml",
        "<skill-name>-wiki/SKILL.md"
      ]
    }
  },
  "test_scenarios": [
    {
      "id": "bench-001",
      "description": "创建简单 Skill（1-2 个模块）",
      "complexity": "low",
      "expected_tokens": "< 10000",
      "expected_latency": "< 15000"
    },
    {
      "id": "bench-002",
      "description": "创建中等复杂度 Skill（3-5 个模块）",
      "complexity": "medium",
      "expected_tokens": "< 20000",
      "expected_latency": "< 30000"
    },
    {
      "id": "bench-003",
      "description": "创建复杂 Skill + 自进化循环",
      "complexity": "high",
      "expected_tokens": "< 40000",
      "expected_latency": "< 50000"
    }
  ]
}